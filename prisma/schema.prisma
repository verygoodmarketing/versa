// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// CORE: Business account (the tenant)
// ============================================================

model Business {
  id          String   @id @default(cuid())
  slug        String   @unique // used for {slug}.ourplatform.com
  name        String
  email       String
  phone       String?
  description String?
  category    String? // e.g. plumber, cleaner, photographer
  logoUrl     String?

  // Custom domain support
  customDomain String? @unique

  // Stripe integration
  stripeCustomerId       String?  @unique
  stripeSubscriptionId   String?
  stripePlanId           String?
  stripeCurrentPeriodEnd DateTime?

  // Status
  isActive Boolean @default(true)
  isPro    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owners     BusinessOwner[]
  site       Site?
  contacts   Contact[]
  bookings   Booking[]
  emailLists EmailList[]

  @@map("businesses")
}

// Business owner (maps to Supabase Auth user)
model BusinessOwner {
  id         String    @id @default(cuid())
  businessId String
  userId     String    @unique // Supabase auth user ID
  role       OwnerRole @default(OWNER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_owners")
}

enum OwnerRole {
  OWNER
  ADMIN
  EDITOR
}

// ============================================================
// SITE: The business's public website
// ============================================================

model Site {
  id         String @id @default(cuid())
  businessId String @unique
  templateId String // reference to a template key (e.g. "cleaners-v1")

  // Site content (block-based JSON)
  config Json @default("{}") // theme colors, fonts, etc.
  blocks Json @default("[]") // ordered array of content blocks

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?

  // Status
  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pages    Page[]

  @@map("sites")
}

// Individual pages within a site (beyond the homepage)
model Page {
  id     String @id @default(cuid())
  siteId String
  slug   String // e.g. "about", "services", "contact"
  title  String
  blocks Json   @default("[]")

  metaTitle       String?
  metaDescription String?

  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@map("pages")
}

// ============================================================
// CRM: Contacts from the business's website visitors
// ============================================================

model Contact {
  id         String  @id @default(cuid())
  businessId String
  email      String
  name       String?
  phone      String?
  message    String? // from contact form
  source     String? // "contact_form", "booking", "email_signup"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([businessId, email])
  @@map("contacts")
}

// ============================================================
// BOOKINGS: Simple appointment/booking system
// ============================================================

model Booking {
  id         String        @id @default(cuid())
  businessId String
  contactId  String?
  status     BookingStatus @default(PENDING)

  serviceName   String
  notes         String?
  requestedDate DateTime
  confirmedDate DateTime?

  customerName  String
  customerEmail String
  customerPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id])

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ============================================================
// EMAIL MARKETING
// ============================================================

model EmailList {
  id          String  @id @default(cuid())
  businessId  String
  name        String
  loopsListId String? // Loops.so external list ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business      Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscriptions EmailSubscription[]
  campaigns     EmailCampaign[]

  @@map("email_lists")
}

model EmailSubscription {
  id          String             @id @default(cuid())
  emailListId String
  email       String
  name        String?
  status      SubscriptionStatus @default(SUBSCRIBED)

  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  emailList EmailList @relation(fields: [emailListId], references: [id], onDelete: Cascade)

  @@unique([emailListId, email])
  @@map("email_subscriptions")
}

enum SubscriptionStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
}

model EmailCampaign {
  id          String         @id @default(cuid())
  emailListId String
  subject     String
  body        String // HTML content
  status      CampaignStatus @default(DRAFT)

  scheduledAt DateTime?
  sentAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailList EmailList @relation(fields: [emailListId], references: [id], onDelete: Cascade)

  @@map("email_campaigns")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}
