# ============================================================
# Supabase — get these from your Supabase project dashboard
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database — Supabase Postgres connection strings
# Get from: Project > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ============================================================
# Stripe — get from https://dashboard.stripe.com/apikeys
# ============================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Payment Link URLs — create in Stripe Dashboard > Payment Links
# Used on /pricing page as direct checkout links (Phase 1 quick path)
STRIPE_PAYMENT_LINK_STARTER=https://buy.stripe.com/...
STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/...
STRIPE_PAYMENT_LINK_BUSINESS=https://buy.stripe.com/...

# Stripe Price IDs — create in Stripe Dashboard > Products
# Used for Checkout Sessions (Phase 2 full integration)
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_BUSINESS=price_...

# ============================================================
# Resend — get from https://resend.com/api-keys
# ============================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@groundworklocal.com

# Feature flag: set to "true" to enable email sending.
# Default is "false" — safe to deploy without Resend configured.
# Set RESEND_ENABLED=true in Vercel env vars to activate all lifecycle emails.
RESEND_ENABLED=false

# ============================================================
# Cron job security — set a random secret in Vercel env vars
# ============================================================
# CRON_SECRET=your-random-secret-here

# ============================================================
# Loops — get from https://app.loops.so/settings?page=api
# ============================================================
LOOPS_API_KEY=your-loops-api-key

# ============================================================
# App config
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# In production: set to your actual domain
# NEXT_PUBLIC_APP_URL=https://app.verygoodmarketing.com
# NEXT_PUBLIC_APP_DOMAIN=verygoodmarketing.com

# ============================================================
# Vercel — domain provisioning (Option C: per-slug subdomains)
# ============================================================
# Get VERCEL_TOKEN from https://vercel.com/account/tokens
# Get VERCEL_PROJECT_ID from Vercel project Settings > General > Project ID
# VERCEL_TEAM_ID is only required for team-owned projects (omit for personal)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=
